# Copy this file to .env for your shell/tooling if you want explicit local paths.
# The current app also works without these variables when run from this repo layout.

STATION_PROXY_PROJECT_DIR=/absolute/path/to/colorado-river-basin-weather
STATION_PROXY_ENGINE_SERVER_DIR=/absolute/path/to/colorado-river-basin-weather/Station_Engine_Server
STATION_PROXY_ENGINE_EXECUTABLE=/absolute/path/to/colorado-river-basin-weather/Station_Engine_Server/station_engine_server
STATION_PROXY_ENGINE_MODE=process
# Use STATION_PROXY_ENGINE_MODE=auto after building the optional native extension.

STATION_PROXY_TARGET_FILE=/absolute/path/to/colorado-river-basin-weather/NOAA_Inventory_Sort/target_daily_app_ready.csv
STATION_PROXY_HUB_FILE=/absolute/path/to/colorado-river-basin-weather/NOAA_Inventory_Sort/hub_daily_app_ready.csv

# Fixture mode for a clean checkout or demo run:
# STATION_PROXY_TARGET_FILE=/absolute/path/to/colorado-river-basin-weather/tests/fixtures/target_daily_app_ready.csv
# STATION_PROXY_HUB_FILE=/absolute/path/to/colorado-river-basin-weather/tests/fixtures/hub_daily_app_ready.csv

# Full NOAA preparation can read yearly GHCN-Daily files from this folder:
STATION_PROXY_GHCN_YEAR_DIR=/absolute/path/to/colorado-river-basin-weather/NOAA_Inventory_Sort/NOAA_GHCN_ByYear

STATION_PROXY_CONFIDENCE_TARGET_CANDIDATES=/absolute/path/to/colorado-river-basin-weather/NOAA_Inventory_Sort/target_station_candidates.csv
STATION_PROXY_CONFIDENCE_HUB_CANDIDATES=/absolute/path/to/colorado-river-basin-weather/NOAA_Inventory_Sort/hub_station_candidates.csv
STATION_PROXY_CONFIDENCE_TERRAIN_FEATURES=/absolute/path/to/colorado-river-basin-weather/terrain_data/processed/station_terrain_features.csv
STATION_PROXY_CONFIDENCE_VALIDATION_METRICS=/absolute/path/to/colorado-river-basin-weather/weather_reconstruction_model/outputs/reports/option_c_limit97_5_hubs_10_target_neighbors_multiscale_terrain_offset_terrain_standard_random_forest_station_metrics.csv

STATION_PROXY_MODEL_RUN_ROOT=/absolute/path/to/colorado-river-basin-weather/weather_reconstruction_model/model_runs
STATION_PROXY_ACTIVE_MODEL_RUN_ID=option_c_limit97_5_hubs_10_target_neighbors_multiscale_terrain_offset_terrain_standard_random_forest
STATION_PROXY_RELIABILITY_MODEL_RUN_ID=paloma_v1_reliability
STATION_PROXY_CONFIDENCE_MODEL_REFERENCE=option-c-multiscale-rf

# Optional label override for confidence scoring responses.
STATION_PROXY_CONFIDENCE_SCORE_VERSION=
